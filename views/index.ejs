<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            min-height: 100vh;
            padding: 20px;
            color: #fff;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
        }
        h1 {
            text-align: center;
            margin-bottom: 30px;
            font-size: 2.5rem;
            background: linear-gradient(90deg, #ff0055, #ffcc00);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .search-box {
            background: rgba(255,255,255,0.1);
            padding: 30px;
            border-radius: 15px;
            backdrop-filter: blur(10px);
        }
        input[type="text"] {
            width: 100%;
            padding: 15px;
            font-size: 16px;
            border: 2px solid rgba(255,255,255,0.2);
            border-radius: 10px;
            background: rgba(0,0,0,0.3);
            color: #fff;
            outline: none;
            transition: border-color 0.3s;
        }
        input[type="text"]:focus {
            border-color: #ff0055;
        }
        button {
            width: 100%;
            padding: 15px;
            margin-top: 15px;
            font-size: 16px;
            font-weight: bold;
            border: none;
            border-radius: 10px;
            background: linear-gradient(90deg, #ff0055, #ff5500);
            color: #fff;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(255,0,85,0.3);
        }
        button:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
        .result {
            margin-top: 30px;
            background: rgba(255,255,255,0.1);
            border-radius: 15px;
            overflow: hidden;
        }
        .video-info {
            display: flex;
            gap: 20px;
            padding: 20px;
        }
        .thumbnail {
            width: 200px;
            border-radius: 10px;
            flex-shrink: 0;
        }
        .video-details h2 {
            font-size: 1.2rem;
            margin-bottom: 10px;
        }
        .video-details p {
            color: rgba(255,255,255,0.7);
            margin-bottom: 5px;
            font-size: 0.9rem;
        }
        .formats {
            padding: 20px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }
        .formats h3 {
            margin-bottom: 15px;
        }
        .format-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 10px;
        }
        .format-btn {
            padding: 12px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 8px;
            color: #fff;
            cursor: pointer;
            transition: all 0.2s;
            text-align: center;
        }
        .format-btn:hover {
            background: #ff0055;
            border-color: #ff0055;
        }
        .progress-container {
            display: none;
            margin-top: 20px;
        }
        .progress-bar {
            height: 10px;
            background: rgba(255,255,255,0.2);
            border-radius: 5px;
            overflow: hidden;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #ff0055, #ffcc00);
            width: 0%;
            transition: width 0.3s;
        }
        .progress-text {
            text-align: center;
            margin-top: 10px;
            color: rgba(255,255,255,0.7);
        }
        .api-endpoints {
            margin-top: 40px;
            background: rgba(255,255,255,0.05);
            padding: 20px;
            border-radius: 10px;
        }
        .api-endpoints h3 {
            margin-bottom: 15px;
        }
        .endpoint {
            background: rgba(0,0,0,0.3);
            padding: 10px 15px;
            border-radius: 5px;
            margin-bottom: 10px;
            font-family: monospace;
            font-size: 0.9rem;
        }
        .endpoint code {
            color: #ffcc00;
        }
        .error {
            background: rgba(255,0,0,0.2);
            padding: 15px;
            border-radius: 10px;
            margin-top: 20px;
            color: #ff6b6b;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📺 YouTube Downloader API</h1>
        
        <div class="search-box">
            <input type="text" id="urlInput" placeholder="Paste YouTube URL here..." />
            <button id="getInfoBtn" onclick="getVideoInfo()">Get Video Info</button>
        </div>
        
        <div class="progress-container" id="progressContainer">
            <div class="progress-bar">
                <div class="progress-fill" id="progressFill"></div>
            </div>
            <p class="progress-text" id="progressText">Downloading... 0%</p>
        </div>
        
        <div id="result"></div>
        
        <div class="api-endpoints">
            <h3>API Endpoints</h3>
            <div class="endpoint"><code>GET /api/info?url=&lt;URL&gt;</code> - Get video info</div>
            <div class="endpoint"><code>GET /api/formats?url=&lt;URL&gt;</code> - Get available formats</div>
            <div class="endpoint"><code>GET /api/download?url=&lt;URL&gt;&amp;formatId=&lt;FORMAT&gt;</code> - Download video</div>
            <div class="endpoint"><code>POST /api/download</code> - Download with JSON body</div>
        </div>
    </div>
    
    <script>
        const API_URL = '<%= apiUrl %>';
        let currentUrl = '';
        let currentFormats = [];
        
        async function getVideoInfo() {
            const url = document.getElementById('urlInput').value.trim();
            if (!url) return alert('Please enter a URL');
            
            const btn = document.getElementById('getInfoBtn');
            btn.disabled = true;
            btn.textContent = 'Loading...';
            
            try {
                const res = await fetch(`${API_URL}/api/formats?url=${encodeURIComponent(url)}`);
                const data = await res.json();
                
                if (data.error) throw new Error(data.error);
                
                currentUrl = url;
                currentFormats = data.formats || [];
                
                displayResult(data);
            } catch (err) {
                document.getElementById('result').innerHTML = `<div class="error">${err.message}</div>`;
            } finally {
                btn.disabled = false;
                btn.textContent = 'Get Video Info';
            }
        }
        
        function displayResult(data) {
            const formatsHtml = currentFormats.slice(0, 12).map(f => 
                `<button class="format-btn" onclick="downloadVideo('${f.format_id}')">
                    ${f.resolution} (${f.ext.toUpperCase()})
                </button>`
            ).join('');
            
            document.getElementById('result').innerHTML = `
                <div class="result">
                    <div class="video-info">
                        <img class="thumbnail" src="${data.thumbnail}" alt="Thumbnail" />
                        <div class="video-details">
                            <h2>${data.title}</h2>
                            <p>👤 ${data.uploader}</p>
                            <p>⏱️ ${formatDuration(data.duration)}</p>
                        </div>
                    </div>
                    <div class="formats">
                        <h3>Select Quality</h3>
                        <div class="format-grid">
                            <button class="format-btn" onclick="downloadVideo('best')">Best Quality</button>
                            ${formatsHtml}
                        </div>
                    </div>
                </div>
            `;
        }
        
        function formatDuration(seconds) {
            if (!seconds) return 'Unknown';
            const h = Math.floor(seconds / 3600);
            const m = Math.floor((seconds % 3600) / 60);
            const s = seconds % 60;
            return h > 0 ? `${h}:${m}:${s}` : `${m}:${s}`;
        }
        
        function downloadVideo(formatId) {
            const container = document.getElementById('progressContainer');
            const fill = document.getElementById('progressFill');
            const text = document.getElementById('progressText');
            
            container.style.display = 'block';
            fill.style.width = '0%';
            text.textContent = 'Starting download...';
            
            const url = `${API_URL}/api/download?url=${encodeURIComponent(currentUrl)}&formatId=${formatId}`;
            
            window.open(url, '_blank');
            
            let progress = 0;
            const interval = setInterval(() => {
                progress += Math.random() * 10;
                if (progress > 90) clearInterval(interval);
                fill.style.width = Math.min(progress, 90) + '%';
                text.textContent = `Downloading... ${Math.floor(progress)}%`;
            }, 500);
        }
    </script>
</body>
</html>
